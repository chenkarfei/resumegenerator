rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE UTILITIES ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- ENTITY VALIDATIONS ---

    function isValidResume(data) {
      return data.keys().hasAll(['resumeData', 'theme', 'color', 'updatedAt'])
        && data.resumeData is map
        && data.theme is string && data.theme.size() <= 64
        && data.color is string && data.color.size() <= 32
        && data.updatedAt is string // In this app it is stored as ISO string in the payload
        && (data.coverLetter == null || data.coverLetter is string)
        && (data.jobMatches == null || data.jobMatches is list);
    }

    // --- COLLECTIONS ---

    match /resumes/{userId} {
      // 3. Path Variable Hardening
      allow get: if isOwner(userId) && isValidId(userId);
      
      // 8. Secure List Queries (though current app only uses 'get')
      allow list: if isOwner(userId);

      allow create: if isOwner(userId) 
        && isValidId(userId)
        && isValidResume(incoming())
        && incoming().keys().size() <= 7; // Prevent shadow fields

      allow update: if isOwner(userId)
        && isValidId(userId)
        && isValidResume(incoming())
        && (
          // Action: Full Update (app usually does this)
          incoming().diff(existing()).affectedKeys().hasAny(['resumeData', 'theme', 'color', 'coverLetter', 'jobMatches', 'updatedAt'])
        );

      allow delete: if isOwner(userId);
    }
  }
}
